# ESPHome シークレットのサンプル。
#
# 実体の secrets.yaml はリポジトリに含めず、リモート側で管理する
# (host.yml の preserveRemoteFiles で cmt の同期・削除対象から除外済み)。
# 既存のリモート secrets.yaml には既に wifi_* が設定されているため、通常は変更不要。
#
# 設定方法のいずれか:
#   A) ESPHome ダッシュボード (http://<home-ep>:6052) の右上「Secrets」エディタ。
#   B) リモートの esphome_config/secrets.yaml に直接配置する。
#
# 注: API 暗号化キー / OTA パスワードはデバイス YAML に直書きしているため、ここには不要。
wifi_ssid: "YOUR_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"
