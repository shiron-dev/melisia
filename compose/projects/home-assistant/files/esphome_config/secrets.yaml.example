# ESPHome シークレットのサンプル。
#
# 実体の secrets.yaml はリポジトリに含めず、リモート側で管理する
# (host.yml の preserveRemoteFiles で cmt の同期・削除対象から除外済み)。
# 既存のリモート secrets.yaml には既に wifi_* が設定されているため、通常は変更不要。
#
# 設定方法のいずれか:
#   A) ESPHome ダッシュボード (http://<home-ep>:6052) の右上「Secrets」エディタ。
#   B) リモートの esphome_config/secrets.yaml に直接配置する。
#
# API 暗号化キー / OTA パスワードはデバイスごとに secrets.yaml で管理する
# (各デバイス YAML から !secret で参照)。値は ESPHome の API キー生成や
# `openssl rand -hex 16` 等で生成する。
wifi_ssid: "YOUR_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"

# AtomS3R Echo Base (音声サテライト)
api_encryption_key: "BASE64_32BYTE_KEY"
ota_password: "HEX_OTA_PASSWORD"

# M5Dial (コントローラー)
m5dial_api_encryption_key: "BASE64_32BYTE_KEY"
m5dial_ota_password: "HEX_OTA_PASSWORD"

# M5Stack AtomS3-Lite (環境センサー)
atom_s3_lite_api_key: "BASE64_32BYTE_KEY"
atom_s3_lite_ota_password: "HEX_OTA_PASSWORD"
