#!/usr/bin/env python3
import ipaddress
import json
import os
import subprocess
import sys
import urllib.error
import urllib.request


def main():
    endpoint = require_env("CLOUDFLARE_MESH_DNS_UPDATER_ENDPOINT")
    client_id = require_env("CF_ACCESS_CLIENT_ID")
    client_secret = require_env("CF_ACCESS_CLIENT_SECRET")
    mesh_cidr = ipaddress.ip_network(require_env("CLOUDFLARE_MESH_DNS_UPDATER_MESH_CIDR"))
    mesh_ip_override = os.environ.get("CLOUDFLARE_MESH_DNS_UPDATER_MESH_IP", "").strip()

    mesh_ip = mesh_ip_override or find_mesh_ip(mesh_cidr)
    if mesh_ip is None:
        raise RuntimeError(f"no IPv4 address found within {mesh_cidr}")
    if ipaddress.ip_address(mesh_ip) not in mesh_cidr:
        raise RuntimeError(f"{mesh_ip} is not within {mesh_cidr}")

    update_dns(endpoint, client_id, client_secret, mesh_ip)
    print(f"Updated Mesh DNS to {mesh_ip}")


def require_env(name):
    value = os.environ.get(name)
    if not value:
        raise RuntimeError(f"{name} is required")
    return value


def find_mesh_ip(mesh_cidr):
    output = subprocess.check_output(["ip", "-j", "-4", "addr", "show"], text=True)
    for interface in json.loads(output):
        for address in interface.get("addr_info", []):
            ip = ipaddress.ip_address(address["local"])
            if ip in mesh_cidr:
                return str(ip)
    return None


def update_dns(endpoint, client_id, client_secret, mesh_ip):
    body = json.dumps({"ip": mesh_ip}).encode("utf-8")
    request = urllib.request.Request(
        endpoint,
        data=body,
        method="POST",
        headers={
            "Content-Type": "application/json",
            "User-Agent": "melisia-cloudflare-mesh-dns-updater/1.0",
            "CF-Access-Client-Id": client_id,
            "CF-Access-Client-Secret": client_secret,
        },
    )

    try:
        with urllib.request.urlopen(request, timeout=30) as response:
            response_body = response.read().decode("utf-8")
    except urllib.error.HTTPError as error:
        response_body = error.read().decode("utf-8", errors="replace")
        raise RuntimeError(f"Worker returned HTTP {error.code}: {response_body}") from error

    parsed = json.loads(response_body)
    if not parsed.get("ok"):
        raise RuntimeError(f"Worker did not report success: {response_body}")


if __name__ == "__main__":
    try:
        main()
    except Exception as error:
        print(f"cloudflare-mesh-dns-update: {error}", file=sys.stderr)
        sys.exit(1)
